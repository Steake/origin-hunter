# Optional API keys — all integrations degrade gracefully if absent.
# Copy to .env and fill in what you have.

# Censys (https://search.censys.io/account/api)
CENSYS_API_ID=
CENSYS_API_SECRET=

# Shodan (https://account.shodan.io)
SHODAN_API_KEY=

# FOFA (https://fofa.info/userInfo)
FOFA_EMAIL=
FOFA_KEY=

# ZoomEye (https://www.zoomeye.hk/profile)
ZOOMEYE_API_KEY=
